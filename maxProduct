
const maxProduct = (nums) => {
    let max = nums[0];
    let min = nums[0];
    let res = nums[0];
    for (let i = 1; i < nums.length; i++) {
        let temp = [nums[i], nums[i] * min, nums[i] * max];
        min = Math.min(...temp);
        max = Math.max(...temp);
        res = Math.max(res, max);
    }
    return res;
}

console.log([2, 3, -2, 4])
console.log(maxProduct([2, 3, -2, 4]));  //output=6
console.log(maxProduct([-2, 0, -1])); //output=0
