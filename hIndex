const hIndex = citations => {
    citations.sort((a, b) => b - a);
    let h = 0;  // Initialize H-Index
    for (let i = 0; i < citations.length; i++) {
        if (citations[i] >= i + 1) {
            h = i + 1;  // Update h when the condition holds
        } else {
            break;  // If condition fails, stop further checks
        }
    }
    return h;  // Return the H-Index
}

console.log(hIndex([3, 0, 6, 1, 5])) //op:-3
console.log(hIndex([1, 3, 1])) //op:-1
