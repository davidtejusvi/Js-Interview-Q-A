// Example 1:
// Input: nums1 = [1,2,2,1], nums2 = [2,2]
// Output: [2,2]
// Example 2:
// Input: nums1 = [4,9,5], nums2 = [9,4,9,8,4]
// Output: [4,9]

const interSectionTwoArr = (nums1, nums2) => {
    let hashMap = {};
    let res = [];
    for (const num of nums1) {
        hashMap[num] = (hashMap[num] || 0) + 1;
    }

    for (const num of nums2) {
        if (hashMap[num] > 0) {
            res.push(num)
            hashMap[num]--;
        }
    }
    return res;
}
