//yeild or generator function - convert function into generator function

function getMultipleValue() {
    return 10;
    return 20;
}

function* getMultipleValue() {
    yield 10;
    yield 20;
}
const res = getMultipleValue();
console.log(res.next().value) // print 10 value
console.log(res.next().value) // print 20 value

