//Method 1: Sort the Array (Simple Approach)
const secondLargestElmArr = (arr) => {
    // Remove duplicates if needed
    let uniqArr = [...new Set(arr)];

    // Sort in descending order
    uniqArr.sort((a, b) => b - a);
    return uniqArr[1];
}

//Method 2: Single Pass Approach (More Efficient)

const secondLargest = (arr) => {
    let first, second = -Infinity;
    for (let num of arr) {
        if (num > first) {
            second = first;
            first = num;
        } else if (num > second && num !== first) {
            second = num;
        }
    }
    return second !== -Infinity ? second : undefined;
}
// Example usage:
console.log(secondLargest([12, 35, 1, 10, 34, 1])); // 34

