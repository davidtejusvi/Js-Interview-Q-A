
const isPalindrome = (x) => {
    let revStr = '';
    let str = x.toString();
    for (let char of str) {
        revStr = char + revStr;
    }
    return (revStr === str);

}
console.log(isPalindrome(121))  // true //Explanation: 121 reads as 121 from left to right and from right to left.
console.log(isPalindrome(-121))  //false //Explanation: From left to right, it reads -121. From right to left,
// it becomes 121-. Therefore it is not a palindrome.
console.log(isPalindrome(10)) //false //Explanation: Reads 01 from right to left. Therefore it is not a palindrome.

